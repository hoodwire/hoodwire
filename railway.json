{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'no build step: the gateway runs TypeScript directly via tsx'"
  },
  "deploy": {
    "startCommand": "npm run serve:gateway",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
