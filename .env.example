# ---- gateway ----
GATEWAY_PORT=8787
# optional: when set, POST /call requires `Authorization: Bearer <key>`
GATEWAY_API_KEY=
# private key of the gateway operator wallet (testnet only!)
OPERATOR_PRIVATE_KEY=
# RPC endpoint (anvil local / testnet)
RPC_URL=http://127.0.0.1:8545
# chain id of the target network (31337 anvil, 46630 Robinhood testnet)
CHAIN_ID=31337
# optional: real Chainlink price feeds as JSON symbol->aggregator address,
# from https://docs.robinhood.com/chain/oracles-and-price-feeds/
# e.g. CHAINLINK_FEEDS={"tNVDA":"0x...","tAAPL":"0x..."}
CHAINLINK_FEEDS=
# deployed contract addresses (fill after `forge script Deploy`)
SETTLEMENT_ESCROW_ADDRESS=
VENDOR_REGISTRY_ADDRESS=
REPUTATION_ADDRESS=
USDG_ADDRESS=
